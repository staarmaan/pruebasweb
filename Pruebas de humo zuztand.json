    {
      "name": "Obtener paciente por ID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Validar codigo 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Validar que tenga los 6 campos requeridos', function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('caretaker');",
              "    pm.expect(jsonData).to.have.property('email');",
              "    pm.expect(jsonData).to.have.property('date');",
              "    pm.expect(jsonData).to.have.property('symptoms');",
              "});",
              "",
              "pm.test('Validar ID no nulo y existente', function () {",
              "    let jsonData = pm.response.json();",
              "    let idEsperado = pm.variables.get('paciente_id');",
              "    pm.expect(jsonData.id).to.equal(idEsperado);",
              "    pm.expect(jsonData.id).to.not.be.null;",
              "});",
              "",
              "pm.test('Tiempo de respuesta menor a 200ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
