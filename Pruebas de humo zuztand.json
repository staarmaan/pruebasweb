  "item": [
    {
      "name": "Crear nuevo paciente valido",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Validacion de codigo 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('Validar que tenga los 6 campos requeridos', function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('id');",
              "    pm.expect(jsonData).to.have.property('name');",
              "    pm.expect(jsonData).to.have.property('caretaker');",
              "    pm.expect(jsonData).to.have.property('email');",
              "    pm.expect(jsonData).to.have.property('date');",
              "    pm.expect(jsonData).to.have.property('symptoms');",
              "});",
              "",
              "pm.test('Validar ID no nulo', function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData.id).to.not.be.null;",
              "    pm.expect(jsonData.id).to.be.a('string');",
              "    pm.expect(jsonData.id.length).to.be.greaterThan(0);",
              "});",
              "",
              "pm.test('Tiempo de respuesta menor a 200ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(200);",
              "});",
              "",
              "//Guardar el ID para usar en otras pruebas.",
              "let jsonData = pm.response.json();",
              "pm.environment.set('paciente_id', jsonData.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json",
            "type": "text"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Filomena\",\n  \"caretaker\": \"Juan Orozco\",\n  \"email\": \"carlosjuan@gmail.com\",\n  \"date\": \"2025-03-10\",\n  \"symptoms\": \"Mucha comezon\"\n}"
        },
        "url": {
          "raw": "http://localhost:3000/api/pacientes",
          "protocol": "http",
          "host": [
            "localhost"
          ],
          "port": "3000",
          "path": [
            "api",
            "pacientes"
          ]
        },
        "description": "Crear un nuevo paciente con datos válidos"
      },
      "response": []
    },
    {
      "name": "Validar datos incompletos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Validar codigo 400, por datos incompletos', function () {",
              "    pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('Validar que la respuesta tenga mensaje de error', function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('error');",
              "    pm.expect(jsonData.error).to.include('Faltan campos');",
              "});",
              "",
              "pm.test('Tiempo de respuesta menor a 200ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
