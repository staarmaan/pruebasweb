    {
      "name": "Validar arreglo de pacientes",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Validacion de codigo 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Validar que la rspuesta sea un arreglo de pacientes', function () {",
              "    let jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});",
              "",
              "pm.test('Validar que todos los pacientes en el array tengan los 6 campos requeridos', function () {",
              "    let jsonData = pm.response.json();",
              "    if (jsonData.length > 0) {",
              "        jsonData.forEach(function(paciente) {",
              "            pm.expect(paciente).to.have.property('id');",
              "            pm.expect(paciente).to.have.property('name');",
              "            pm.expect(paciente).to.have.property('caretaker');",
              "            pm.expect(paciente).to.have.property('email');",
              "            pm.expect(paciente).to.have.property('date');",
              "            pm.expect(paciente).to.have.property('symptoms');",
              "            pm.expect(paciente.id).to.not.be.null;",
              "        });",
              "    }",
              "});",
              "",
              "pm.test('Tiempo de respuesta menor a 200ms', function () {",
              "    pm.expect(pm.response.responseTime).to.be.below(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:3000/api/pacientes",
          "protocol": "http",
